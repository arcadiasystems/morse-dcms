{
	"name": "@arcadiasystems/morse-sdk",
	"version": "0.3.0",
	"description": "TypeScript SDK for Morse dCMS on the Sui blockchain.",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"keywords": [
		"sui",
		"walrus",
		"seal",
		"cms",
		"decentralized",
		"blockchain"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arcadiasystems/morse-dcms.git",
		"directory": "morse-sdk"
	},
	"homepage": "https://github.com/arcadiasystems/morse-dcms/tree/main/morse-sdk#readme",
	"bugs": {
		"url": "https://github.com/arcadiasystems/morse-dcms/issues"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"prebuild": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun test",
		"test:coverage": "bun test --coverage"
	},
	"engines": {
		"bun": ">=1.2.0",
		"node": ">=18.0.0"
	},
	"peerDependencies": {
		"@mysten/seal": ">=1.1.3 <1.2.0",
		"@mysten/sui": ">=2.16.2 <2.17.0",
		"@mysten/walrus": ">=1.1.6 <1.2.0"
	},
	"peerDependenciesMeta": {
		"@mysten/seal": {
			"optional": true
		},
		"@mysten/walrus": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@mysten/bcs": "2.0.3",
		"@mysten/seal": "1.1.3",
		"@mysten/sui": "2.16.2",
		"@mysten/walrus": "1.1.6",
		"@types/bun": "latest",
		"typescript": "^5.6.0"
	}
}
