# Copy to .env.local and fill in real values.
# .env.local is gitignored.

# suiprivkey1... bech32 secret key.
# Get it via: sui keytool export --key-identity <alias>
PRIVATE_KEY=

# Current `published-at` of the Morse `publication` package (Move call target).
# Updates on every `sui client upgrade`.
PACKAGE_ID=

# Optional: `original-id` of the package (canonical type identity from
# Published.toml). Stable across upgrades. If omitted, defaults to PACKAGE_ID
# which is the correct value for a fresh deploy with no upgrades.
# ORIGINAL_PACKAGE_ID=

# Shared `PublicationRegistry` object ID created at the original publish.
REGISTRY_ID=

# Optional: override the default testnet RPC URL.
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
