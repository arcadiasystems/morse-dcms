{
	"name": "@arcadiasystems/morse-cli",
	"version": "0.1.0",
	"description": "Command-line interface for the Morse decentralized CMS on Sui.",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"sui",
		"walrus",
		"seal",
		"cms",
		"cli",
		"decentralized",
		"blockchain"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arcadiasystems/morse-dcms.git",
		"directory": "morse-cli"
	},
	"homepage": "https://github.com/arcadiasystems/morse-dcms/tree/main/morse-cli#readme",
	"bugs": {
		"url": "https://github.com/arcadiasystems/morse-dcms/issues"
	},
	"bin": {
		"morse": "./src/index.ts"
	},
	"files": [
		"src",
		"docs",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"engines": {
		"bun": ">=1.2.0"
	},
	"scripts": {
		"start": "bun src/index.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"prepublishOnly": "tsc --noEmit && biome check . && bun test"
	},
	"dependencies": {
		"@arcadiasystems/morse-sdk": "^0.1.4",
		"@mysten/seal": "1.1.3",
		"@mysten/sui": "2.16.2",
		"@mysten/walrus": "1.1.6",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@types/bun": "latest",
		"typescript": "^5.6.0"
	}
}
