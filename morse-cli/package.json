{
	"name": "@arcadiasystems/morse-cli",
	"version": "0.4.1",
	"description": "Command-line interface for the Morse decentralized CMS on Sui.",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"sui",
		"walrus",
		"seal",
		"cms",
		"cli",
		"decentralized",
		"blockchain"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arcadiasystems/morse-dcms.git",
		"directory": "morse-cli"
	},
	"homepage": "https://github.com/arcadiasystems/morse-dcms/tree/main/morse-cli#readme",
	"bugs": {
		"url": "https://github.com/arcadiasystems/morse-dcms/issues"
	},
	"bin": {
		"morse": "./dist/index.js"
	},
	"files": [
		"dist",
		"docs",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"engines": {
		"node": ">=18",
		"bun": ">=1.2.0"
	},
	"scripts": {
		"start": "bun src/index.ts",
		"build": "bun build src/index.ts --target node --packages external --outfile dist/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "bun test",
		"test:unit": "bun test test/*.test.ts",
		"test:cli": "bun test test/cli/",
		"test:coverage": "bun test --coverage",
		"test:e2e": "MORSE_E2E=1 bun test test/e2e/",
		"coverage": "bun scripts/coverage-gate.ts",
		"check": "tsc --noEmit && biome check . && bun scripts/coverage-gate.ts",
		"prepublishOnly": "bun run check && bun run build"
	},
	"dependencies": {
		"@arcadiasystems/morse-sdk": "^0.4.1",
		"@mysten/seal": "1.1.3",
		"@mysten/sui": "2.16.2",
		"@mysten/walrus": "1.1.6",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@types/bun": "latest",
		"typescript": "^5.6.0"
	}
}
